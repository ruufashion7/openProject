# Option A — project root: copy this file to  .env.local.properties  (gitignored)
# Option B — IntelliJ / Maven: put the same line in  src/main/resources/application-local.properties
#            (also gitignored). No SPRING_PROFILES_ACTIVE needed — it is imported automatically.
#
# Paste the same connection string you use in MongoDB Compass (Atlas):
#   Compass → your connection → "Copy connection string"
# Special characters in the password must be URL-encoded (e.g. @ → %40)
#
mongo_uri=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/openProject
