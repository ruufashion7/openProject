# Local Development Configuration
#
# EASIEST (recommended): copy .env.local.properties.example → .env.local.properties in the
# project root and set mongo_uri there. No IntelliJ profile needed.
#
# ALTERNATIVE: copy this file to src/main/resources/application-local.properties and run with
#   SPRING_PROFILES_ACTIVE=local

# MongoDB Atlas (MongoDB Compass) - full connection string
# If your password contains @, encode it as %40 in the URI
mongo_uri=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/openProject

# OR use individual properties:
# mongo_db_hostname=cluster0.2m4d4r8.mongodb.net
# mongo_db_username=your-username
# mongo_db_password=your-password
# mongo_db_name=openProject
# mongo_db_password_encrypted=false

